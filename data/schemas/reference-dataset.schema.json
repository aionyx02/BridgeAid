{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridgeaid/schemas/reference-dataset.schema.json",
  "title": "BridgeAid Reference Dataset",
  "description": "Annually-updated official figures (e.g. minimum living cost) that service rules reference via `ref` conditions instead of hardcoding derived numbers. Every dataset carries its validity period and official sources so stale values are detectable.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "unit", "period", "values", "default", "sources"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Dataset name that rule conditions reference (ref.dataset)."
    },
    "description": { "type": "string" },
    "unit": { "type": "string", "minLength": 1 },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_from", "valid_to"],
      "properties": {
        "valid_from": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "valid_to": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "values": {
      "type": "object",
      "description": "Keyed by canonical profile token (e.g. residence_city values).",
      "additionalProperties": { "type": "number" }
    },
    "default": {
      "type": "number",
      "description": "Fallback for keys not listed in values. Choose the conservative bound for the dataset's use (e.g. the nationwide minimum)."
    },
    "default_note": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url", "last_checked_at"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "last_checked_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    }
  }
}
