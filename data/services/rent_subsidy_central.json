{
  "id": "rent_subsidy_central",
  "name": "中央租金補貼",
  "category": "housing",
  "jurisdiction": "central",
  "area": { "type": "nationwide" },
  "status": "active",
  "version": "2026.07",
  "eligibility_rules": {
    "all": [
      { "field": "has_lease", "operator": "equals", "value": true },
      { "field": "age", "operator": "gte", "value": 18 },
      { "field": "income_status", "operator": "in", "value": ["low_income", "mid_low_income", "near_threshold", "general"] }
    ]
  },
  "required_documents": [
    { "name": "身分證明文件", "condition": "always" },
    { "name": "租賃契約", "condition": "always" },
    { "name": "收入證明（每人每月平均所得須低於當地最低生活費 3 倍；家庭成員均無自有住宅，由受理機關查調）", "condition": "always" }
  ],
  "conflicts": [
    { "service_id": "social_housing_taipei", "type": "choose_one", "reason": "同一租屋需求，租金補貼與承租社會住宅通常擇一。" }
  ],
  "source": {
    "title": "行政院 - 300億元中央擴大租金補貼專案計畫（延長至115年）",
