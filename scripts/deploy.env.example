# BridgeAid deploy config.
# Copy to scripts/deploy.env (gitignored) and edit for your host.
# Syntax uses ':=' so real environment variables still take precedence.

# Remote host: an ssh alias (see ~/.ssh/config) or user@host.
# Leave unset/commented to build locally on the current machine.
: "${SSH_HOST:=my-vps}"

# Host port published on 127.0.0.1 (the container always listens on 8080).
: "${PORT:=8080}"

# Public URL — shown in the closing message only.
: "${PUBLIC_URL:=https://bridgeaid.example.com}"

# --- optional overrides ---
# : "${IMAGE:=bridgeaid:latest}"
# : "${NAME:=bridgeaid}"
# : "${REMOTE_DIR:=bridgeaid}"          # dir under the remote $HOME
# : "${ENV_FILE:=$HOME/bridgeaid/.line.env}"  # docker --env-file with LINE secrets
